# ╔═══════════════════════════════════════════════════════════════╗
# ║                  🦌⚡ KEYRING SIGNER AGENT                     ║
# ║                     Configuration Template                    ║
# ╚═══════════════════════════════════════════════════════════════╝

# 🌐 HEDERA NETWORK CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
HEDERA_NETWORK=testnet
# 📝 Your Hedera account ID (format: 0.0.xxxxx)
HEDERA_ACCOUNT_ID=0.0.YOUR_ACCOUNT_ID
# 🔐 Your Hedera private key (ED25519 DER format recommended)
# 💡 ED25519 DER keys start with: 302a300506032b657004
HEDERA_PRIVATE_KEY=YOUR_ED25519_DER_PRIVATE_KEY_HERE

# 🤖 OPENAI INTEGRATION
# ═══════════════════════════════════════════════════════════════════
# 🧠 OpenAI API key for LangChain agent functionality
OPENAI_API_KEY=sk-your-openai-api-key-here
# 📚 Optional: OpenAI model configuration (defaults to gpt-4o-mini)
# OPENAI_MODEL_NAME=gpt-4o-mini

# 📡 HCS TOPICS
# ═══════════════════════════════════════════════════════════════════
PROJECT_REGISTRY_TOPIC=0.0.YOUR_PROJECT_REGISTRY_TOPIC_ID
PROJECT_CONTRACTS_TOPIC=0.0.YOUR_PROJECT_CONTRACTS_TOPIC_ID
PROJECT_AUDIT_TOPIC=0.0.YOUR_PROJECT_AUDIT_TOPIC_ID
PROJECT_REJECTION_TOPIC=0.0.YOUR_PROJECT_REJECTION_TOPIC_ID
PROJECT_VALIDATOR_REVIEW_TOPIC=0.0.YOUR_PROJECT_VALIDATOR_REVIEW_TOPIC_ID
PROJECT_VALIDATOR_INBOUND_TOPIC=0.0.YOUR_PROJECT_VALIDATOR_INBOUND_TOPIC_ID
# Optional: HIP-991 fee per message in HBAR (default: 0.01)
# VALIDATOR_INBOUND_TOPIC_FEE_HBAR=0.01

# KeyRing operator inbound topic (only KeyRing operator can bypass agent validation)
KEYRING_OPERATOR_INBOUND_TOPIC_ID=0.0.YOUR_KEYRING_OPERATOR_INBOUND_TOPIC_ID
# Optional: fee per message (default: 0.01)
# OPERATOR_INBOUND_TOPIC_FEE_HBAR=0.01

# 🔖 PROJECT REGISTRATION
# ═══════════════════════════════════════════════════════════════════
# Transaction ID from the Lynx project registration (format: 0.0.xxxxx@timestamp.sequence)
LYNX_REGISTRATION_TX=0.0.YOUR_ACCOUNT@timestamp.sequence

#THRESHOLD SIGNERS
OPERATOR_PUBLIC_KEY=YOUR_OPERATOR_PUBLIC_KEY_HERE
TEST_SIGNER1=YOUR_TEST_SIGNER1_PUBLIC_KEY_HERE
TEST_SIGNER2=YOUR_TEST_SIGNER2_PUBLIC_KEY_HERE

# Rejection topic submit keys (mainnet): config/rejection-topic-signers-mainnet.csv + OPERATOR_PUBLIC_KEY + AGENT_CONFIGS
# Override CSV path: REJECTION_TOPIC_SIGNERS_CSV=/path/to/signers.csv
# AGENT_CONFIGS= JSON array of passive agents (operatorPublicKey used for submit key)

#THRESHOLD
THRESHOLD_ACCOUNT_ID=0.0.YOUR_THRESHOLD_ACCOUNT_ID_HERE

# SCHEDULE REVIEW (passive agents)
# REQUIRED: Contract operator key (ECDSA/secp256k1 DER) — account that creates schedules, must call scheduleReviewTrigger. EVM: 0xb19907... for 0.0.9651200.
CONTRACT_OPERATOR_KEY=YOUR_CONTRACT_OPERATOR_DER_KEY
# Comma-separated inbound topic IDs for passive agents on the threshold list
PASSIVE_AGENT_INBOUND_TOPICS=0.0.TOPIC1,0.0.TOPIC2
# Schedule review contract address (0.0.xxxxx or 0x...)
SCHEDULE_REVIEW_CONTRACT_ID=0.0.YOUR_SCHEDULE_REVIEW_CONTRACT_ID
# Optional override: EVM private key (32-byte hex). If unset, uses CONTRACT_OPERATOR_KEY.
# SCHEDULE_REVIEW_EVM_PRIVATE_KEY=0x...
# Optional: Hedera JSON-RPC URL (default: Hashio testnet/mainnet)
# HEDERA_JSON_RPC_URL=https://testnet.hashio.io/api


# 🧪 TEST TRANSACTION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
# REQUIRED: Lynx testnet operator (creates test transactions)
# Lynx operator (testnet)
LYNX_TESTNET_OPERATOR_ID=0.0.YOUR_LYNX_OPERATOR_ACCOUNT_ID
LYNX_TESTNET_OPERATOR_KEY=YOUR_LYNX_OPERATOR_PRIVATE_KEY
# Lynx operator (mainnet) - used when HEDERA_NETWORK=mainnet
# LYNX_OPERATOR_ACCOUNT_ID=0.0.YOUR_MAINNET_OPERATOR_ACCOUNT_ID
# LYNX_OPERATOR_KEY=YOUR_MAINNET_OPERATOR_PRIVATE_KEY
# Lynx contract operator - account that creates schedules (from getScheduleEnv). If set, used for mirror node schedule query.
# LYNX_CONTRACT_OPERATOR_ACCOUNT_ID=0.0.YOUR_CONTRACT_OPERATOR_ACCOUNT_ID
# REQUIRED: Lynx DepositMinterV2 testnet contract address
LYNX_TESTNET_CONTRACT=0.0.6755211
# Lynx LP Manager (VaultLPManager) - used for ABI selection when decoding createLPPosition etc.
# LYNX_LP_MANAGER_CONTRACT=0.0.7842637

# 🔧 OPTIONAL CONFIGURATIONS
# ═══════════════════════════════════════════════════════════════════
# 🌐 Mirror node URL (uses Agent Kit defaults if not specified)
# HEDERA_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
# 🔗 Consensus node URL (uses Agent Kit defaults if not specified)
# HEDERA_CONSENSUS_NODE_URL=0.testnet.hedera.com:50211

# ═══════════════════════════════════════════════════════════════════
# 💡 TIP: Copy this file to .env and fill in your actual values
# 🔒 SECURITY: Never commit your .env file to version control!
# 🤝 INTEGRATION: Works with Lynx Governance Agent V2
# ═══════════════════════════════════════════════════════════════════